# ===========================================================================
# BIND / MULTI-PORT
# ===========================================================================
# 0.0.0.0 => dapat diakses dari luar (VPS). 127.0.0.1 => lokal saja.
HOST=0.0.0.0
PORT=5032

# Multi-port launcher (launcher.py):
#   - PORTS: list/range eksplisit (prioritas tertinggi). Contoh:
#       PORTS=5032,5033,5034          -> 3 port
#       PORTS=5032-5041               -> 10 port (5032..5041)
#   - atau pakai PORT_START + PORT_COUNT:
#       PORT_START=5032
#       PORT_COUNT=5
PORTS=5032-5036
# PORT_START=5032
# PORT_COUNT=5

# ===========================================================================
# BROWSER POOL (per worker / per port)
#   kapasitas solve concurrent per port = THREAD x PAGE_COUNT
# ===========================================================================
HEADLESS=True
THREAD=2
PAGE_COUNT=10
PROXY_SUPPORT=false

# ===========================================================================
# UVICORN TUNING (brutal concurrency, per port)
# ===========================================================================
UVICORN_WORKERS=1
LIMIT_CONCURRENCY=5000
BACKLOG=8192
TIMEOUT_KEEP_ALIVE=30
ACCESS_LOG=false

# ===========================================================================
# WORKER MANAGER (launcher.py)
# ===========================================================================
RESTART_ON_CRASH=true
RESTART_DELAY=3
WORKER_SPAWN_STAGGER=1.5

# ===========================================================================
# CLEANUP / LOGGING
# ===========================================================================
CLEANUP_INTERVAL_MINUTES=60
LOG_LEVEL=INFO
LOG_ROTATION=10 MB
LOG_RETENTION=7 days
